#include <SoftwareSerial.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1 
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

#define txPin 6
#define rxPin 7
#define micPin A0 
SoftwareSerial mySerial(rxPin, txPin);

int Motor_IA1 = 10; int Motor_IB1 = 9;  
int Motor_IA2 = 11; int Motor_IB2 = 3;  
const int MP3_ADDR = 0x7B; 

const int sampleWindow = 100; 
unsigned int peakToPeak = 0;
int soundThreshold = 510; 

bool isAutoMoving = false;
bool isManualMoving = false;
unsigned long demoStartTime = 0;
const int demoDuration = 6000; 
unsigned long lastRockTime = 0;
int rockStep = 0; 
int triggerCount = 0; 
unsigned long lastTriggerTime = 0;

void setup() {
  mySerial.begin(9600);
  Wire.begin(); 
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    mySerial.println(F("OLED Error: 0x3C not found"));
  } else {
    display.clearDisplay();
    display.setTextColor(SSD1306_WHITE);
    updateScreen("SYSTEM READY", "Monitoring...");
  }
  pinMode(Motor_IA1, OUTPUT); pinMode(Motor_IB1, OUTPUT);
  pinMode(Motor_IA2, OUTPUT); pinMode(Motor_IB2, OUTPUT);
  pinMode(13, OUTPUT);
  stopMotors();
}

void loop() {
  if (mySerial.available() > 0) {
    char cmd = toupper((char)mySerial.read());
    handleCommand(cmd);
  }
  if (!isAutoMoving && !isManualMoving) {
    checkMic();
  }
  if (isAutoMoving) {
    if (millis() - demoStartTime < demoDuration) {
      handleRocking(); 
    } else {
      stopAutoResponse(); 
    }
  }
}

void handleRocking() {
  unsigned long now = millis();
  if (now - lastRockTime > 400) { 
    lastRockTime = now;
    rockStep = (rockStep + 1) % 4;
    switch(rockStep) {
      case 0: moveForward(); break;
      case 1: stopMotors(); break;
      case 2: moveBackward(); break;
      case 3: stopMotors(); break;
    }
  }
}

void checkMic() {
  unsigned long startMillis = millis();
  unsigned int signalMax = 0;
  unsigned int signalMin = 1024;
  while (millis() - startMillis < 100) {
    unsigned int sample = analogRead(micPin);
    if (sample < 1024) {
      if (sample > signalMax) signalMax = sample;
      else if (sample < signalMin) signalMin = sample;
    }
  }
  peakToPeak = signalMax - signalMin;
  static unsigned long lastDisplay = 0;
  if (millis() - lastDisplay > 500) { 
    drawVolumeBar();
    lastDisplay = millis();
  }
  if (peakToPeak > soundThreshold) {
    unsigned long now = millis();
    if (now - lastTriggerTime > 2000) triggerCount = 0;
    triggerCount++;
    lastTriggerTime = now;
    if (triggerCount >= 3) {
      triggerCount = 0;
      startAutoResponse();
    }
  }
}

void startAutoResponse() {
  isAutoMoving = true;
  demoStartTime = millis();
  lastRockTime = millis();
  rockStep = 0;
  updateScreen("CRY DETECTED!", "Action: ROCKING");
  playMP3(1);     
  digitalWrite(13, HIGH);
}

void stopAutoResponse() {
  isAutoMoving = false;
  stopMotors();
  digitalWrite(13, LOW);
  updateScreen("BABY CALM", "Status: MONITORING");
}

void handleCommand(char cmd) {
  switch(cmd) {
    case 'W': moveForward(); isManualMoving = true; updateScreen("MANUAL", "Forward"); break;
    case 'S': moveBackward(); isManualMoving = true; updateScreen("MANUAL", "Backward"); break;
    case 'A': turnLeft(); isManualMoving = true; updateScreen("MANUAL", "Turn Left"); break;
    case 'D': turnRight(); isManualMoving = true; updateScreen("MANUAL", "Turn Right"); break;
    case 'F': stopMotors(); stopMP3(); isManualMoving = false; updateScreen("STOP", "Idle"); break;
    case '1': playMP3(1); break;
    case '2': playMP3(2); break;
  }
}

void moveForward() { analogWrite(Motor_IA2, 100); digitalWrite(Motor_IA1, LOW); analogWrite(Motor_IB1, 100); digitalWrite(Motor_IB2, LOW); }
void moveBackward() { digitalWrite(Motor_IA2, LOW); analogWrite(Motor_IA1, 100); digitalWrite(Motor_IB1, LOW); analogWrite(Motor_IB2, 100); }
void turnLeft() { digitalWrite(Motor_IA2, LOW); analogWrite(Motor_IA1, 75); analogWrite(Motor_IB1, 75); digitalWrite(Motor_IB2, LOW); }
void turnRight() { analogWrite(Motor_IA2, 75); digitalWrite(Motor_IA1, LOW); digitalWrite(Motor_IB1, LOW); analogWrite(Motor_IB2, 75); }
void stopMotors() { digitalWrite(Motor_IA1, LOW); digitalWrite(Motor_IA2, LOW); digitalWrite(Motor_IB1, LOW); digitalWrite(Motor_IB2, LOW); }

void updateScreen(String title, String subtitle) {
  display.clearDisplay();
  display.setTextSize(1); display.setCursor(0,0);
  display.println("SMART BABY CRADLE");
  display.drawLine(0, 10, 128, 10, SSD1306_WHITE);
  display.setCursor(0, 20); display.setTextSize(2); display.println(title);
  display.setTextSize(1); display.setCursor(0, 45); display.println(subtitle);
  display.display();
}

void drawVolumeBar() {
  int barWidth = map(peakToPeak, 0, 800, 0, 128);
  if (barWidth > 128) barWidth = 128;
  display.fillRect(0, 58, 128, 6, SSD1306_BLACK); 
  display.drawRect(0, 58, 128, 6, SSD1306_WHITE); 
  display.fillRect(0, 58, barWidth, 6, SSD1306_WHITE); 
  display.display();
}

void playMP3(uint16_t trackNum) {
  uint8_t low = trackNum & 0xFF; uint8_t high = (trackNum >> 8) & 0xFF;
  Wire.beginTransmission(MP3_ADDR); Wire.write(0x01); Wire.write(low); Wire.write(high); Wire.endTransmission();
}
void stopMP3() { Wire.beginTransmission(MP3_ADDR); Wire.write(0x06); Wire.endTransmission(); }
