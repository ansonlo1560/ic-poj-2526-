#include <SoftwareSerial.h>
#include <Wire.h>


#define txPin 6
#define rxPin 7
SoftwareSerial mySerial(rxPin, txPin);




// 馬達腳位 (L9110S)
int Motor_IA1 = 10; int Motor_IB1 = 9;  
int Motor_IA2 = 11; int Motor_IB2 = 3;  




// Hiwonder MP3 I2C 定義
const int MP3_ADDR = 0x7B; // 修正位址




void setup() {
  mySerial.begin(9600);
  Wire.begin();
 
  pinMode(Motor_IA1, OUTPUT); pinMode(Motor_IB1, OUTPUT);
  pinMode(Motor_IA2, OUTPUT); pinMode(Motor_IB2, OUTPUT);
  pinMode(13, OUTPUT);
 
  stopMotors();
  mySerial.println("V4 Fixed. W/S/A/D to move, 1-2 to Play, F to Stop");
}




void loop() {
  if (mySerial.available() > 0) {
    char cmd = toupper((char)mySerial.read());
    switch(cmd) {
      case 'W': moveForward(); break;
      case 'S': moveBackward(); break;
      case 'A': turnLeft(); break;
      case 'D': turnRight(); break;
      case 'F': stopMotors(); stopMP3(); break;
      case '1': playMP3(1); break;
      case '2': playMP3(2); break;
      default: blinkError(); break;
    }
  }
}




// --- 運動控制 (L9110S 正確邏輯) ---
void moveForward() {
  analogWrite(Motor_IA2, 180); digitalWrite(Motor_IA1, LOW); // 右輪前
  analogWrite(Motor_IB1, 180); digitalWrite(Motor_IB2, LOW); // 左輪前
}




void moveBackward() {
  digitalWrite(Motor_IA2, LOW); analogWrite(Motor_IA1, 180); // 右輪後
  digitalWrite(Motor_IB1, LOW); analogWrite(Motor_IB2, 180); // 左輪後
}




void turnLeft() {
  digitalWrite(Motor_IA2, LOW); analogWrite(Motor_IA1, 150); // 右後
  analogWrite(Motor_IB1, 150); digitalWrite(Motor_IB2, LOW); // 左前
}




void turnRight() {
  analogWrite(Motor_IA2, 150); digitalWrite(Motor_IA1, LOW); // 右前
  digitalWrite(Motor_IB1, LOW); analogWrite(Motor_IB2, 150); // 左後
}




void stopMotors() {
  digitalWrite(Motor_IA1, LOW); digitalWrite(Motor_IA2, LOW);
  digitalWrite(Motor_IB1, LOW); digitalWrite(Motor_IB2, LOW);
}




// --- MP3 控制 ---
void playMP3(uint16_t trackNum) {
  uint8_t low = trackNum & 0xFF;
  uint8_t high = (trackNum >> 8) & 0xFF;
  Wire.beginTransmission(MP3_ADDR);
  Wire.write(0x01); // 播放曲目寄存器
  Wire.write(low);
  Wire.write(high);
  Wire.endTransmission();
}




void stopMP3() {
  Wire.beginTransmission(MP3_ADDR);
  Wire.write(0x06); // 暫停寄存器
  Wire.endTransmission();
}




void blinkError() {
  digitalWrite(13, HIGH); delay(50); digitalWrite(13, LOW);
}


